esac
BRANCH="$(sanitize_branch "${BRANCH}")"; write_conf INSTALLER_BRANCH "\"${BRANCH}\""
[ -z "$(nvram get odmpid 2>/dev/null)" ] && ROUTER_MODEL="$(nvram get productid 2>/dev/null)" || ROUTER_MODEL="$(nvram get odmpid 2>/dev/null)"
[ -z "${ROUTER_MODEL}" ] && PTXT "${ERROR}Unsupported router." && sleep 3s && exit 1
