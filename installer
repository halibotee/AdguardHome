case "${ROUTER_OS}" in Linux) [ -z "$2" ] && PTXT "Linux platform."; ROUTER_OS="linux";; *) PTXT "${ERROR}Unsupported OS."; exit 1;; esac
case "$(/bin/uname -m)" in
