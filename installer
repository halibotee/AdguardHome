	armv7l) ROUTER_ARCH="armv7"; URL_ARCH="${RURL}"; ADGUARD_ARCH="${ROUTER_OS}_${ROUTER_ARCH}";;
	armv7) ROUTER_ARCH="armv5"; URL_ARCH="${RURL}"; ADGUARD_ARCH="${ROUTER_OS}_${ROUTER_ARCH}";;
	*) PTXT "${ERROR} Unsupported arch."; exit 1;;
esac
[ -z "$2" ] && PTXT "${INFO} Architecture: ${ROUTER_ARCH}"

init_remote_adguard_metadata
case "$2" in
	"") cleanup; check_jffs_enabled; check_dns_environment 0; check_version; menu;;
	[1-5]|install|update|uninstall|changepw|reconfigure|amtmupdate|[bB]|backup|[rR]|restore) menu "$2";;
