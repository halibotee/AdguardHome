#!/bin/sh
######################################
# AdGuardHome Installer (2026.06.13)
######################################

export LC_ALL=C
export PATH="/sbin:/bin:/usr/sbin:/usr/bin:${PATH}"

AI_VERSION="v1.0"
export AI_VERSION
readonly ADGUARD_METADATA_FILE="/tmp/AGH_STATIC_METADATA_$$.txt"
readonly ADGUARDHOME_WAIT_TIMEOUT="60"
readonly ADGUARDHOME_READY_TIMEOUT="180"
readonly ADDON_DIR="/jffs/addons/AdGuardHome.d"
readonly BASE_DIR="/opt/etc"
readonly TARG_DIR="${BASE_DIR}/AdGuardHome"
readonly AGH_FILE="${TARG_DIR}/AdGuardHome"
readonly CONF_FILE="${TARG_DIR}/.config"
readonly YAML_FILE="${AGH_FILE}.yaml"
readonly YAML_BAK="${YAML_FILE}.bak"
readonly YAML_ERR="${YAML_FILE}.err"
readonly YAML_ORI="${TARG_DIR}/.AdGuardHome.yaml.ori"
SCRIPT_LOC="$(readlink -f "$0")" || true
readonly SCRIPT_LOC

BOLD="$(printf "\033[1m")" || true
readonly BOLD
NORM="$(printf "\033[0m")" || true
readonly NORM
INFO="$(printf "%s" "${BOLD}Info: ${NORM}")" || true
readonly INFO
ERROR="$(printf "%s" "${BOLD}***Error: ${NORM}")" || true
readonly ERROR
WARNING="$(printf "%s" "${BOLD}*Warning: ${NORM}")" || true
readonly WARNING
INPUT="$(printf "%s" "${BOLD}=> ${NORM}")" || true
readonly INPUT

# ===== FUNCTIONS =====

# --- Print ---
PTXT() { case "$1" in -n) shift; while [ $# -gt 0 ]; do printf "%s" "$1"; shift; done ;; *) while [ $# -gt 0 ]; do printf "%s\n" "$1"; shift; done ;; esac; }

_quote() { PTXT "$1" | sed 's/[]\/()$*.^|[]/\\&/g'; }
branch_is_safe() { case "$1" in "" | /* | */ | *..* | *//* | *\\* | *[!abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789._/-]*) return 1 ;; esac; return 0; }
conf_value() { [ -f "${CONF_FILE}" ] || return 1; awk -v KEY="$1" 'index($0, KEY "=")==1{VALUE=substr($0,length(KEY)+2);gsub(/^"|"$/,"",VALUE);print VALUE;exit}' "${CONF_FILE}"; }
md5_is_valid() { [ "$(PTXT -n "$1" | wc -c)" -eq 32 ] && PTXT -n "$1" | grep -qiE '^[0-9a-f]{32}$'; }
sanitize_branch() { if branch_is_safe "$1"; then PTXT "$1"; else PTXT "master"; fi; }

# --- Bootstrap ---
ai_have_cmd() { which "$1" >/dev/null 2>&1; }
cleanup_api_files() { rm -f "${ADGUARD_METADATA_FILE}"; }
ensure_password_hash_tool() { ai_have_cmd python3 && python3 -c 'import bcrypt' >/dev/null 2>&1 && return 0; opkg install python3 python3-bcrypt >/dev/null 2>&1; ai_have_cmd python3 && python3 -c 'import bcrypt' >/dev/null 2>&1; }
hash_password_python() { PTXT -n "$1" | python3 -c 'import sys, bcrypt; password = sys.stdin.buffer.read(); print(bcrypt.hashpw(password, bcrypt.gensalt(prefix=b"2a", rounds=10)).decode("ascii"))'; }
remove_conflicting_apache() { if opkg list-installed 2>/dev/null | awk -v pkg="apache" '$1==pkg{f=1;exit}END{exit(f?0:1)}' || opkg list-installed 2>/dev/null | awk -v pkg="apache-utils" '$1==pkg{f=1;exit}END{exit(f?0:1)}'; then opkg flag user apache apache-utils >/dev/null 2>&1; opkg remove apache apache-utils --force-removal-of-dependent-packages >/dev/null 2>&1; fi; }

# --- HTTP ---
curl_help() { if [ -z "${CURL_HELP_CACHE_SET:-}" ]; then CURL_HELP_CACHE="$(curl --help all 2>&1 || curl --help 2>&1)"; CURL_HELP_CACHE_SET="1"; fi; PTXT "${CURL_HELP_CACHE}"; }
curl_has_option() { curl_help | grep -q -e "$1"; }
curl_common_args() { if [ -z "${CURL_COMMON_ARGS_SET:-}" ]; then CURL_COMMON_ARGS=""; curl_has_option '--retry' && CURL_COMMON_ARGS="${CURL_COMMON_ARGS} --retry 5"; curl_has_option '--connect-timeout' && CURL_COMMON_ARGS="${CURL_COMMON_ARGS} --connect-timeout 25"; curl_has_option '--retry-delay' && CURL_COMMON_ARGS="${CURL_COMMON_ARGS} --retry-delay 5"; curl_has_option '--max-time' && CURL_COMMON_ARGS="${CURL_COMMON_ARGS} --max-time 125"; curl_has_option '--retry-connrefused' && CURL_COMMON_ARGS="${CURL_COMMON_ARGS} --retry-connrefused"; CURL_COMMON_ARGS_SET="1"; fi; PTXT -n "${CURL_COMMON_ARGS}"; }
curl_insecure_arg() { if [ -z "${CURL_INSECURE_ARG_SET:-}" ]; then CURL_INSECURE_ARG=""; curl_has_option '--insecure' && CURL_INSECURE_ARG=" -k"; CURL_INSECURE_ARG_SET="1"; fi; PTXT -n "${CURL_INSECURE_ARG}"; }
wget_help() { if [ -z "${WGET_HELP_CACHE_SET:-}" ]; then WGET_HELP_CACHE="$(wget --help 2>&1)"; WGET_HELP_CACHE_SET="1"; fi; PTXT "${WGET_HELP_CACHE}"; }
wget_has_option() { wget_help | grep -q -e "$1"; }
wget_common_args() { if [ -z "${WGET_COMMON_ARGS_SET:-}" ]; then WGET_COMMON_ARGS=""; wget_has_option '--no-cache' && WGET_COMMON_ARGS="${WGET_COMMON_ARGS} --no-cache"; wget_has_option '--no-cookies' && WGET_COMMON_ARGS="${WGET_COMMON_ARGS} --no-cookies"; wget_has_option '--tries' && WGET_COMMON_ARGS="${WGET_COMMON_ARGS} --tries=5"; wget_has_option '--timeout' && WGET_COMMON_ARGS="${WGET_COMMON_ARGS} --timeout=25"; wget_has_option '--waitretry' && WGET_COMMON_ARGS="${WGET_COMMON_ARGS} --waitretry=5"; wget_has_option '--retry-connrefused' && WGET_COMMON_ARGS="${WGET_COMMON_ARGS} --retry-connrefused"; WGET_COMMON_ARGS_SET="1"; fi; PTXT -n "${WGET_COMMON_ARGS}"; }
wget_insecure_arg() { if [ -z "${WGET_INSECURE_ARG_SET:-}" ]; then WGET_INSECURE_ARG=""; wget_has_option '--no-check-certificate' && WGET_INSECURE_ARG=" --no-check-certificate"; WGET_INSECURE_ARG_SET="1"; fi; PTXT -n "${WGET_INSECURE_ARG}"; }
http_get_file() { local URL OUT HEADERS INSECURE; URL="$1"; OUT="$2"; HEADERS="${3:-}"; INSECURE="${4:-}"; if ai_have_cmd curl; then local CURL_ARGS="$(curl_common_args)"; [ "${INSECURE}" = "insecure" ] && CURL_ARGS="${CURL_ARGS}$(curl_insecure_arg)"; if [ -n "${HEADERS}" ]; then curl ${CURL_ARGS} -D "${HEADERS}" -f -sL "${URL}" -o "${OUT}"; else curl ${CURL_ARGS} -f -sL "${URL}" -o "${OUT}"; fi; elif ai_have_cmd wget; then local WGET_ARGS="$(wget_common_args)"; [ "${INSECURE}" = "insecure" ] && WGET_ARGS="${WGET_ARGS}$(wget_insecure_arg)"; if [ -n "${HEADERS}" ] && wget_has_option '--server-response'; then wget ${WGET_ARGS} --server-response -q -O "${OUT}" "${URL}" 2>"${HEADERS}"; else [ -n "${HEADERS}" ] && : >"${HEADERS}"; wget ${WGET_ARGS} -q -O "${OUT}" "${URL}"; fi; else return 127; fi; }
http_get_stdout() { local URL INSECURE; URL="$1"; INSECURE="${2:-}"; if ai_have_cmd curl; then local CURL_ARGS="$(curl_common_args)"; [ "${INSECURE}" = "insecure" ] && CURL_ARGS="${CURL_ARGS}$(curl_insecure_arg)"; curl ${CURL_ARGS} -f -sL "${URL}"; elif ai_have_cmd wget; then local WGET_ARGS="$(wget_common_args)"; [ "${INSECURE}" = "insecure" ] && WGET_ARGS="${WGET_ARGS}$(wget_insecure_arg)"; wget ${WGET_ARGS} -q -O - "${URL}"; else return 127; fi; }
http_probe() { local URL PROBE_TIMEOUT; URL="$1"; PROBE_TIMEOUT="${2:-}"; if ai_have_cmd curl; then local CURL_ARGS="$(curl_common_args)"; if [ -n "${PROBE_TIMEOUT}" ]; then curl_has_option '--retry' && CURL_ARGS="${CURL_ARGS} --retry 0"; curl_has_option '--connect-timeout' && CURL_ARGS="${CURL_ARGS} --connect-timeout ${PROBE_TIMEOUT}"; curl_has_option '--max-time' && CURL_ARGS="${CURL_ARGS} --max-time ${PROBE_TIMEOUT}"; fi; curl ${CURL_ARGS} -f -sL -I -o /dev/null "${URL}"; elif ai_have_cmd wget; then local WGET_ARGS="$(wget_common_args)"; if [ -n "${PROBE_TIMEOUT}" ]; then wget_has_option '--tries' && WGET_ARGS="${WGET_ARGS} --tries=1"; wget_has_option '--timeout' && WGET_ARGS="${WGET_ARGS} --timeout=${PROBE_TIMEOUT}"; wget_has_option '--waitretry' && WGET_ARGS="${WGET_ARGS} --waitretry=0"; fi; if wget_has_option '--spider'; then wget ${WGET_ARGS} -q --spider "${URL}"; else wget ${WGET_ARGS} -q -O /dev/null "${URL}"; fi; else return 127; fi; }

# --- Process helpers ---
agh_is_running() { [ -n "$(pidof AdGuardHome)" ]; }
agh_monitor_count() { local count pid; count="0"; for pid in $(pidof AdGuardHome.sh S99AdGuardHome rc.func.AdGuardHome 2>/dev/null); do if awk '{print}' "/proc/${pid}/cmdline" 2>/dev/null | grep -q 'monitor-start'; then count="$((count+1))"; fi; done; PTXT "${count}"; }
agh_process_count() { PTXT "$(($(pidof AdGuardHome 2>/dev/null | wc -w)+$(agh_monitor_count)))"; }
agh_prepare_binary_replace() { if { [ -f "${AGH_FILE}" ] || [ -e "/opt/sbin/AdGuardHome" ]; } && [ "$(agh_process_count)" -ge "1" ]; then PTXT "${INFO}Stopping AdGuardHome before replacing binary."; agh_stop || return 1; fi; return 0; }
agh_wait_started() { local e=0 m="${1:-${ADGUARDHOME_WAIT_TIMEOUT}}"; while ! agh_is_running; do [ ${e} -ge ${m} ] && return 1; sleep 1s; e=$((e+1)); done; return 0; }
agh_wait_stopped() { local e=0 m="${1:-${ADGUARDHOME_WAIT_TIMEOUT}}"; while [ "$(agh_process_count)" -ge 1 ]; do [ ${e} -ge ${m} ] && return 1; sleep 1s; e=$((e+1)); done; return 0; }
agh_check() { [ -x "/opt/etc/init.d/S99AdGuardHome" ] && /opt/etc/init.d/S99AdGuardHome check; }

agh_stop() {
	if [ "$(agh_process_count)" -ge 1 ]; then
		if service stop_AdGuardHome >/dev/null 2>&1; then sleep 1s
		elif /opt/etc/init.d/S99AdGuardHome stop; then sleep 1s
		elif /opt/etc/init.d/S99AdGuardHome kill; then sleep 1s
		else killall -q -9 AdGuardHome 2>/dev/null; rm -f /opt/var/run/AdGuardHome.pid 2>/dev/null; sleep 1s; fi
	fi
	sleep 1s; agh_wait_stopped "${ADGUARDHOME_WAIT_TIMEOUT}" || { PTXT "${ERROR}Timed out waiting for stop."; return 1; }; sleep 1s; agh_check; return 0
}

agh_start() {
	if ! agh_is_running; then
		if service start_AdGuardHome >/dev/null 2>&1; then sleep 1s
		elif /opt/etc/init.d/S99AdGuardHome start; then sleep 1s
		else return 1; fi
	fi
	sleep 1s; agh_wait_started "${ADGUARDHOME_WAIT_TIMEOUT}" || { PTXT "${ERROR}Timed out waiting for start."; return 1; }; sleep 1s; agh_check; agh_is_running
}

agh_restart() {
	if agh_is_running; then
		if service restart_AdGuardHome >/dev/null 2>&1; then sleep 1s
		elif /opt/etc/init.d/S99AdGuardHome restart; then sleep 1s
		else return 1; fi
	else agh_start || return 1; fi
	sleep 1s; agh_wait_ready "${ADGUARDHOME_READY_TIMEOUT}" || { PTXT "${ERROR}Timed out waiting for network checks."; return 1; }; sleep 1s; agh_check; agh_is_running
}

agh_start_error() { PTXT "${ERROR}Couldn't start AdGuardHome! Please send log to dev."; }

agh_wait_ready() {
	local e=0 m="${1:-${ADGUARDHOME_READY_TIMEOUT}}" n r s; s="$(monotonic_seconds)" || return 1
	while :; do n="$(monotonic_seconds)" || return 1; e=$((n-s)); [ ${e} -ge ${m} ] && return 1; r=$((m-e))
		if check_connection "${r}" && agh_is_running; then return 0; fi
		n="$(monotonic_seconds)" || return 1; e=$((n-s)); [ ${e} -ge ${m} ] && return 1; sleep 1s; done
}

agh_complete_startup() {
	PTXT "Starting AdGuardHome..."; agh_stop
	agh_start || { agh_start_error; return 1; }
	PTXT "Performing final check."; agh_restart || { agh_start_error; return 1; }
	PTXT "AdGuardHome setup complete."; return 0
}

monotonic_seconds() { local u; if read -r u _ </proc/uptime; then u="${u%%.*}"; case "${u}" in ""|*[!0-9]*) return 1;; esac; PTXT "${u}"; return 0; fi; return 1; }

# --- AdGuardHome auth ---
AdGuardHome_authen() {
	if [ -z "${PW1}" ] || [ -z "${PW2}" ]; then local USERNAME; PTXT -n "${INPUT}Enter AdGuardHome username${NORM}: "; read -r USERNAME; fi
	local PW1 PW2; PTXT -n "${INPUT}Enter AdGuardHome password${NORM}: "; read -rs PW1; PTXT " "
	PTXT -n "${INPUT}Reenter password${NORM}: "; read -rs PW2; PTXT " "
	if [ -z "${PW1}" ] || [ -z "${PW2}" ] || [ "${PW1}" != "${PW2}" ]; then PTXT "${ERROR}Password mismatch!"; AdGuardHome_authen "$1"; return; fi
	remove_conflicting_apache
	ensure_password_hash_tool || { PTXT "${ERROR}Unable to install password hashing tool."; end_op_message 1; return; }
	local PW1_ENCRYPTED=""; if python3 -c 'import bcrypt' >/dev/null 2>&1; then PW1_ENCRYPTED="$(hash_password_python "${PW1}")" || PW1_ENCRYPTED=""; fi
	case "${PW1_ENCRYPTED}" in \$2a\$10\$*) ;; *) PTXT "${ERROR}Password could not be set!"; end_op_message 1; return ;; esac
	if [ "$1" -eq 0 ]; then
		yaml_nvars_delete "- name:" "${YAML_FILE}"; yaml_nvars_delete "  password:" "${YAML_FILE}"
		yaml_nvars_insert "users:" "\  password: ${PW1_ENCRYPTED}" "${YAML_FILE}"; yaml_nvars_insert "users:" "- name: ${USERNAME}" "${YAML_FILE}"
		check_AdGuardHome_yaml "${YAML_FILE}"; agh_complete_startup || { end_op_message 1; return; }; end_op_message 0
	else PTXT "users:" "- name: ${USERNAME}" "  password: ${PW1_ENCRYPTED}" >>"${YAML_ORI}"; fi
}

# --- Metadata ---
adguard_remote_archive() { case "$1" in release) PTXT "${REMOTE_RELEASE_ARCHIVE}";; beta) PTXT "${REMOTE_BETA_ARCHIVE}";; edge) PTXT "${REMOTE_EDGE_ARCHIVE}";; *) return 1;; esac; }
adguard_remote_md5() { case "$1" in release) PTXT "${REMOTE_RELEASE_MD5}";; beta) PTXT "${REMOTE_BETA_MD5}";; edge) PTXT "${REMOTE_EDGE_MD5}";; *) return 1;; esac; }
adguard_remote_version() { case "$1" in release) PTXT "${REMOTE_VER}";; beta) PTXT "${REMOTE_BETA}";; edge) PTXT "${REMOTE_EDGE}";; *) return 1;; esac; }
adguard_remote_url() { case "$1" in release) PTXT "${REMOTE_RELEASE_URL}";; beta) PTXT "${REMOTE_BETA_URL}";; edge) PTXT "${REMOTE_EDGE_URL}";; *) return 1;; esac; }

init_adguard_metadata_defaults() {
	REMOTE_RELEASE_ARCHIVE="AdGuardHome_${ADGUARD_ARCH}.tar.gz"; REMOTE_BETA_ARCHIVE="AdGuardHome_${ADGUARD_ARCH}.tar.gz"; REMOTE_EDGE_ARCHIVE="AdGuardHome_${ADGUARD_ARCH}.tar.gz"
	REMOTE_RELEASE_MD5=""; REMOTE_BETA_MD5=""; REMOTE_EDGE_MD5=""
	REMOTE_RELEASE_URL="https://static.adguard.com/adguardhome/release/${REMOTE_RELEASE_ARCHIVE}"
	REMOTE_BETA_URL="https://static.adguard.com/adguardhome/beta/${REMOTE_BETA_ARCHIVE}"
	REMOTE_EDGE_URL="https://static.adguard.com/adguardhome/edge/${REMOTE_EDGE_ARCHIVE}"
}

init_remote_adguard_metadata() {
	REMOTE_VER=""; REMOTE_BETA=""; REMOTE_EDGE=""; REMOTE_RELEASE_ARCHIVE=""; REMOTE_BETA_ARCHIVE=""; REMOTE_EDGE_ARCHIVE=""
	REMOTE_RELEASE_MD5=""; REMOTE_BETA_MD5=""; REMOTE_EDGE_MD5=""; REMOTE_RELEASE_URL=""; REMOTE_BETA_URL=""; REMOTE_EDGE_URL=""
	init_upstream_adguard_metadata
}

init_upstream_adguard_metadata() {
	init_adguard_metadata_defaults
	local rvm="${ADGUARD_METADATA_FILE}.r" bvm="${ADGUARD_METADATA_FILE}.b" evm="${ADGUARD_METADATA_FILE}.e" c=0
	while [ ${c} -lt 2 ]; do
		rm -f "${rvm}" "${bvm}" "${evm}"
		if http_get_file "https://static.adguard.com/adguardhome/release/version.txt" "${rvm}" "" insecure && [ -s "${rvm}" ] &&
		   http_get_file "https://static.adguard.com/adguardhome/beta/version.txt" "${bvm}" "" insecure && [ -s "${bvm}" ] &&
		   http_get_file "https://static.adguard.com/adguardhome/edge/version.txt" "${evm}" "" insecure && [ -s "${evm}" ]; then
			REMOTE_VER="$(awk 'NF{VERSION=$1;sub(/^version=/,"",VERSION);print VERSION;exit}' "${rvm}")"
			REMOTE_BETA="$(awk 'NF{VERSION=$1;sub(/^version=/,"",VERSION);print VERSION;exit}' "${bvm}")"
			REMOTE_EDGE="$(awk 'NF{VERSION=$1;sub(/^version=/,"",VERSION);print VERSION;exit}' "${evm}")"
			if [ -n "${REMOTE_VER}" ] && [ -n "${REMOTE_BETA}" ] && [ -n "${REMOTE_EDGE}" ]; then
				for v in REMOTE_VER REMOTE_BETA REMOTE_EDGE REMOTE_RELEASE_ARCHIVE REMOTE_BETA_ARCHIVE REMOTE_EDGE_ARCHIVE REMOTE_RELEASE_MD5 REMOTE_BETA_MD5 REMOTE_EDGE_MD5 REMOTE_RELEASE_URL REMOTE_BETA_URL REMOTE_EDGE_URL; do export ${v}; done
				rm -f "${rvm}" "${bvm}" "${evm}"; return 0
			fi
		fi; c=$((c+1))
	done
	rm -f "${rvm}" "${bvm}" "${evm}"
	PTXT "Warning: Could not fetch version info. Using defaults."
	for v in REMOTE_VER REMOTE_BETA REMOTE_EDGE REMOTE_RELEASE_ARCHIVE REMOTE_BETA_ARCHIVE REMOTE_EDGE_ARCHIVE REMOTE_RELEASE_MD5 REMOTE_BETA_MD5 REMOTE_EDGE_MD5 REMOTE_RELEASE_URL REMOTE_BETA_URL REMOTE_EDGE_URL; do export ${v}; done
}

# --- DNS Environment ---
check_connection() {
	local d i l=0 m n r s; m="${1:-}"; if [ -n "${m}" ]; then n="$(monotonic_seconds)"; d=$((n+m)); fi
	while [ ${l} -lt 4 ]; do
		for i in google.com github.com snbforums.com; do
			if [ -n "${d}" ]; then n="$(monotonic_seconds)"; [ ${n} -ge ${d} ] && return 1; fi
			if { ! nslookup "${i}" 127.0.0.1 >/dev/null 2>&1; } && { ping -q -w3 -c1 "${i}" >/dev/null 2>&1; }; then
				r=""; if [ -n "${d}" ]; then n="$(monotonic_seconds)"; r=$((d-n)); [ ${r} -le 0 ] && return 1; fi
				if ! http_probe "http://${i}" "${r}" >/dev/null 2>&1; then if [ -n "${d}" ]; then n="$(monotonic_seconds)"; [ ${n} -ge ${d} ] && return 1; fi; sleep 1s; continue; fi
			fi; return 0
		done
		l=$((l+1)); if [ ${l} -lt 4 ]; then if [ -n "${d}" ]; then n="$(monotonic_seconds)"; s=$((d-n)); [ ${s} -le 0 ] && return 1; [ ${s} -gt 10 ] && s=10; sleep ${s}s; else sleep 10s; fi; fi
	done; return 1
}

save_dns_nvram_environment() {
	for VAR in dnspriv_enable dhcpd_dns_router dhcp_dns1_x dhcp_dns2_x; do
		local V="$(nvram get "${VAR}" 2>/dev/null)"
		case "${VAR}" in dnspriv_enable) _OLD_dnspriv_enable="${V}";; dhcpd_dns_router) _OLD_dhcpd_dns_router="${V}";; dhcp_dns1_x) _OLD_dhcp_dns1_x="${V}";; dhcp_dns2_x) _OLD_dhcp_dns2_x="${V}";; esac
	done
	for v in _OLD_dnspriv_enable _OLD_dhcpd_dns_router _OLD_dhcp_dns1_x _OLD_dhcp_dns2_x; do export ${v}; done; _DNS_NVRAM_SAVED="1"; export _DNS_NVRAM_SAVED
}

check_dns_environment() {
	if [ -f "/opt/etc/init.d/S61stubby" ] || [ -f "/opt/sbin/stubby" ] || [ -f "/opt/bin/install_stubby" ] || [ -f "/jffs/scripts/install_stubby.sh" ] || [ -d "/jffs/dnscrypt" ] || [ -f "/opt/etc/init.d/S09dnscrypt-proxy" ]; then
		PTXT "${ERROR}Stubby or dnscrypt-proxy detected. Please remove first."; exit 1
	fi
	local MODE NVCHECK=0
	dns_env_set_nvram() { local k="$1" e="$2" c; c="$(nvram get "${k}" 2>/dev/null)"; [ "${c}" = "${e}" ] && return 1; nvram set "${k}=${e}"; return 0; }
	dns_env_apply_profile() { local c=0; dns_env_set_nvram "dnspriv_enable" "0" && c=$((c+1)); dns_env_set_nvram "dhcpd_dns_router" "1" && c=$((c+1)); dns_env_set_nvram "dhcp_dns1_x" "" && c=$((c+1)); dns_env_set_nvram "dhcp_dns2_x" "" && c=$((c+1)); [ ${c} -ne 0 ]; }
	dns_env_restore_profile() { local c=0 k; for k in dnspriv_enable dhcpd_dns_router dhcp_dns1_x dhcp_dns2_x; do local cu ol; cu="$(nvram get "${k}" 2>/dev/null)"; eval "ol=\"\$_OLD_${k}\""; [ "${cu}" != "${ol}" ] && { nvram set "${k}=${ol}"; c=$((c+1)); }; done; [ ${c} -ne 0 ]; }
	MODE="$1"
	case "${MODE}" in
		0) if [ "${_DNS_NVRAM_SAVED:-0}" != "1" ]; then save_dns_nvram_environment; fi; [ "$(pidof stubby)" ] && { killall -q -9 stubby 2>/dev/null; NVCHECK=$((NVCHECK+1)); }; dns_env_apply_profile && NVCHECK=$((NVCHECK+1));;
		1) [ "${_DNS_NVRAM_SAVED:-0}" != "1" ] && return 0; dns_env_restore_profile && NVCHECK=$((NVCHECK+1));;
		*) return 1;;
	esac
	[ ${NVCHECK} -ne 0 ] && { nvram commit; service restart_dnsmasq >/dev/null 2>&1; (while ! check_connection; do sleep 1s; done) & local P=$!; wait ${P} 2>/dev/null; }
	PTXT "DNS Environment is Ready."; return 0
}

check_dns_filter() {
	local NVCHECK=0 USE_SOME
	if [ "$1" -eq 0 ]; then [ "$(nvram get dnsfilter_enable_x)" -ne 0 ] && { nvram set dnsfilter_enable_x="0"; NVCHECK=$((NVCHECK+1)); }; PTXT "DNS not forced through."; fi
	if [ "$1" -eq 1 ]; then
		[ "$(nvram get dnsfilter_enable_x)" -ne 1 ] && { nvram set dnsfilter_enable_x="1"; NVCHECK=$((NVCHECK+1)); }
		read_yesno "Redirect only non-custom DNS?" && USE_SOME=0 || USE_SOME=1
		if [ ${USE_SOME} -eq 0 ]; then [ "$(nvram get dnsfilter_mode)" != "11" ] && { nvram set dnsfilter_mode="11"; NVCHECK=$((NVCHECK+1)); }; fi
		if [ ${USE_SOME} -eq 1 ]; then
			for i in dnsfilter_mode dhcpd_dns_router dnsfilter_custom1 dnsfilter_custom2 dnsfilter_custom3 dnsfilter_rulelist dnsfilter_rulelist1 dnsfilter_rulelist2 dnsfilter_rulelist3 dnsfilter_rulelist4 dnsfilter_rulelist5 dhcp_dns1_x dhcp_dns2_x; do
				local VAR="$(nvram get "${i}" 2>/dev/null)"
				if [ "${i}" = "dnsfilter_mode" ]; then [ "$VAR" != "11" ] && { nvram set "${i}"="11"; } || continue
				elif [ "${i}" = "dhcpd_dns_router" ]; then [ "$VAR" != "1" ] && { nvram set "${i}"="1"; } || continue
				elif [ "$VAR" ]; then nvram set "${i}"=""; else continue; fi
				NVCHECK=$((NVCHECK+1))
			done
		fi
	fi
	[ ${NVCHECK} -ne 0 ] && { nvram commit; service "restart_firewall;restart_dnsmasq" >/dev/null 2>&1; check_connection 300 || PTXT "${WARNING}Timed out waiting for DNS."; }
}

check_dns_local() { case "$1" in 0) write_conf ADGUARD_LOCAL "\"NO\"";; 1) write_conf ADGUARD_LOCAL "\"YES\"";; esac; }

check_jffs_enabled() {
	[ "$(nvram get jffs2_format)" = "1" ] && { PTXT "${ERROR}JFFS scheduled for reformat. Reboot first."; exit 1; }
	local JFFS2_SCRIPTS JFFS2_ENABLED jffs2_on; JFFS2_SCRIPTS="$(nvram get jffs2_scripts)"
	[ -z "$(nvram get jffs2_enable)" ] && JFFS2_ENABLED="$(nvram get jffs2_on)" || JFFS2_ENABLED="$(nvram get jffs2_enable)"
	[ -z "$(nvram get jffs2_enable)" ] && jffs2_on="jffs2_on" || jffs2_on="jffs2_enable"
	if [ "${JFFS2_ENABLED}" -ne 1 ] || [ "${JFFS2_SCRIPTS}" -ne 1 ]; then
		PTXT "Enabling JFFS custom scripts and configs."
		nvram set ${jffs2_on}="1"; nvram set jffs2_scripts="1"; nvram commit
	else PTXT "JFFS already enabled."; fi
}

check_AdGuardHome_yaml() { [ ! -f "${YAML_FILE}" ] && return; chmod 644 "${YAML_FILE}"; PTXT "Checking AdGuardHome configuration..."; if ! "${AGH_FILE}" --check-config -c "${YAML_FILE}" --no-check-update -l "/dev/null"; then PTXT "Invalid config -> ${YAML_ERR}"; mv "${YAML_FILE}" "${YAML_ERR}"; return 1; fi; }

check_version() {
	local RMNSTALL LINSTALL MD5SUM_L MD5SUM_R MD5SUM_EXPECTED REMOTE_INSTALLER REMOTE_INSTALLER_MD5 ADGUARD_BRANCH ADGUARD_VER REMOTE_ADGUARD_VER varcnt
	if [ -f "${TARG_DIR}/installer" ] && [ -f "${AGH_FILE}" ] && [ -z "$2" ]; then
		if [ -n "$1" ] || { check_connection; }; then
			REMOTE_INSTALLER="${TARG_DIR}/.installer.remote.$$"; REMOTE_INSTALLER_MD5="${REMOTE_INSTALLER}.md5sum"; varcnt="0"
			until [ -n "${LINSTALL}" ] && [ -n "${RMNSTALL}" ] && [ -n "${MD5SUM_L}" ] && [ -n "${MD5SUM_R}" ]; do
				[ -z "${LINSTALL}" ] && LINSTALL="$(awk -F= '/^AI_VERSION=/ {gsub(/"/,"",$2);sub(/^v/,"",$2);if($2~/^[0-9]{1,2}(\.[0-9]{1,2}){2}$/)print $2;exit}' "${TARG_DIR}/installer")"
				[ -z "${MD5SUM_L}" ] && MD5SUM_L="$(md5sum "${TARG_DIR}/installer" | awk '{print $1;exit}')"
				if [ -z "${RMNSTALL}" ] || [ -z "${MD5SUM_R}" ]; then
					rm -f "${REMOTE_INSTALLER}" "${REMOTE_INSTALLER_MD5}"
					if http_get_file "${RURL}/installer" "${REMOTE_INSTALLER}" && [ -s "${REMOTE_INSTALLER}" ]; then
						RMNSTALL="$(awk -F= '/^AI_VERSION=/ {gsub(/"/,"",$2);sub(/^v/,"",$2);if($2~/^[0-9]{1,2}(\.[0-9]{1,2}){2}$/)print $2;exit}' "${REMOTE_INSTALLER}")"
						MD5SUM_R="$(md5sum "${REMOTE_INSTALLER}" | awk '{print $1;exit}')"
						MD5SUM_EXPECTED=""; http_get_file "${RURL}/installer.md5sum" "${REMOTE_INSTALLER_MD5}" && [ -s "${REMOTE_INSTALLER_MD5}" ] && MD5SUM_EXPECTED="$(awk 'NR==1{print $1;exit}' "${REMOTE_INSTALLER_MD5}")"
						md5_is_valid "${MD5SUM_EXPECTED}" && [ "${MD5SUM_R}" != "${MD5SUM_EXPECTED}" ] && { PTXT "${WARNING}Installer checksum mismatch."; RMNSTALL=""; MD5SUM_R=""; }
					fi
				fi
				[ -n "${LINSTALL}" ] && [ -n "${RMNSTALL}" ] && [ -n "${MD5SUM_L}" ] && [ -n "${MD5SUM_R}" ] && break
				varcnt=$((varcnt+1)); [ ${varcnt} -ge 2 ] && { rm -f "${REMOTE_INSTALLER}" "${REMOTE_INSTALLER_MD5}"; PTXT "Warning: Could not check for installer updates."; break; }
			done
			rm -f "${REMOTE_INSTALLER}" "${REMOTE_INSTALLER_MD5}"
			ADGUARD_BRANCH="$(conf_value ADGUARD_BRANCH)"; ADGUARD_VER="$("${AGH_FILE}" --version | cut -d" " -f4-)"
			REMOTE_ADGUARD_VER="$(adguard_remote_version "${ADGUARD_BRANCH}")"
			[ -n "${RMNSTALL}" ] && [ -n "${LINSTALL}" ] && [ "${RMNSTALL}" != "${LINSTALL}" ] && PTXT "New AI_VERSION=v${RMNSTALL} Available. Run option 1 to upgrade." && AUTO_UPDATE="update"
			[ -n "${RMNSTALL}" ] && [ -n "${LINSTALL}" ] && [ -n "${MD5SUM_R}" ] && [ -n "${MD5SUM_L}" ] && [ "${RMNSTALL}" = "${LINSTALL}" ] && [ "${MD5SUM_R}" != "${MD5SUM_L}" ] && PTXT "AI_VERSION=v${LINSTALL}, minor update available." && AUTO_UPDATE="update"
			[ -n "${REMOTE_ADGUARD_VER}" ] && [ -n "${ADGUARD_VER}" ] && [ "${REMOTE_ADGUARD_VER}" != "${ADGUARD_VER}" ] && PTXT "New ${ADGUARD_BRANCH:-release} ADGUARDHOME_VER=${REMOTE_ADGUARD_VER} Available." && AUTO_UPDATE="update"
		elif [ -z "${LINSTALL}" ] && [ -z "${RMNSTALL}" ] && [ -z "$1" ]; then
			check_connection 5 && check_version x
		else check_version x x; fi
	fi
}

choose_branch() {
	[ "$1" = "1" ] && { ADGUARD_BRANCH_OLD="$(conf_value ADGUARD_BRANCH)"; export ADGUARD_BRANCH_OLD; del_conf ADGUARD_BRANCH; }
	if [ ! -f "${CONF_FILE}" ] || [ -z "$(conf_value ADGUARD_BRANCH)" ]; then
		PTXT "Choose AdGuardHome build:" "  1) Release" "  2) Beta" "  3) Edge"
		read_input_num "Select mode" 1 3
		local BUILD; case ${CHOSEN} in 1) BUILD=release;; 2) BUILD=beta;; 3) BUILD=edge;; esac
		write_conf ADGUARD_BRANCH "\"${BUILD}\""
		[ -n "${ADGUARD_BRANCH_OLD:-}" ] && [ "${ADGUARD_BRANCH_OLD}" != "${BUILD}" ] && { ADGUARD_BRANCH_CHANGED="1"; export ADGUARD_BRANCH_CHANGED; }
	else read_yesno "Switch builds?" && choose_branch 1 || PTXT "Keeping current build."; fi
}

# --- Timezone ---
set_timezone() {
	local TZ_SRC=""
	if [ -L "/etc/localtime" ] 2>/dev/null; then TZ_SRC="$(readlink /etc/localtime)"; PTXT "Detected timezone from /etc/localtime: ${TZ_SRC}"; fi
	if [ -z "${TZ_SRC}" ] && [ -f "/etc/TZ" ]; then
		local TZ_VAL; TZ_VAL="$(cat /etc/TZ 2>/dev/null)"
		[ -n "${TZ_VAL}" ] && PTXT "Detected /etc/TZ: ${TZ_VAL}"
		case "$TZ_VAL" in
			JST-9|JST-9DST) TZ_SRC="Asia/Tokyo";; CST-8|CST-8DST|HKT-8) TZ_SRC="Asia/Shanghai";; SGT-8) TZ_SRC="Asia/Singapore";; EST5DST|EST-5) TZ_SRC="America/New_York";; CST6CDT|CST-6) TZ_SRC="America/Chicago";; MST7MDT|MST-7) TZ_SRC="America/Denver";; PST8PDT|PST-8) TZ_SRC="America/Los_Angeles";; GMT0|GMT-0|UTC0) TZ_SRC="UTC";; CET-1|CET-1DST) TZ_SRC="Europe/Berlin";; EET-2|EET-2DST) TZ_SRC="Europe/Helsinki";; IST-5:30) TZ_SRC="Asia/Kolkata";; KST-9) TZ_SRC="Asia/Seoul";; AWST-8) TZ_SRC="Australia/Perth";; AEST-10) TZ_SRC="Australia/Sydney";; NZST-12) TZ_SRC="Pacific/Auckland";; BST-1) TZ_SRC="Europe/London";; MSK-3) TZ_SRC="Europe/Moscow";; *)
				[ -n "${TZ_VAL}" ] && TZ_SRC="UTC"
		esac
	fi
	if [ -z "${TZ_SRC}" ] && [ -f "/etc/localtime" ] && [ ! -L "/etc/localtime" ]; then
		local HASH; HASH="$(md5sum /etc/localtime 2>/dev/null | cut -d' ' -f1)"
		for z in Asia/Shanghai Asia/Tokyo Asia/Singapore America/New_York America/Chicago America/Denver America/Los_Angeles Europe/Berlin Europe/London Europe/Moscow Europe/Paris Australia/Sydney Pacific/Auckland UTC; do
			[ "$(md5sum "/usr/share/zoneinfo/${z}" 2>/dev/null | cut -d' ' -f1)" = "${HASH}" ] && { TZ_SRC="${z}"; break; }
		done
	fi
	[ -z "${TZ_SRC}" ] && TZ_SRC="UTC" && PTXT "Timezone not detected, using UTC."
	cp -f /etc/localtime "${ADDON_DIR}/localtime" 2>/dev/null || cp "/usr/share/zoneinfo/${TZ_SRC}" "${ADDON_DIR}/localtime" 2>/dev/null || { PTXT "Could not set timezone, set via WebUI later."; return 0; }
	PTXT "Timezone set to ${TZ_SRC}."; return 0
}

# --- Installer helpers ---
create_dir() { mkdir -p "$1" || { PTXT "${ERROR}Cannot create $1!"; return 1; }; }
del_between_magic() { local TARG="$1" MAGIC="$2"; [ -f "${TARG}" ] || return; local BOUNDS; BOUNDS="$(awk -v PATT="${MAGIC}" '($0~PATT){printf NR","}' "${TARG}")"; [ -n "${BOUNDS}" ] && sed -i "${BOUNDS%,}d" "${TARG}"; }
del_conf() { [ ! -f "${CONF_FILE}" ] && return; for KEY in "$@"; do sed -i "/^${KEY}=.*$/d" "${CONF_FILE}"; done; }
del_jffs_script() { local TARG="$1" LINE_NUM; [ -f "${TARG}" ] || return; LINE_NUM="$(grep -n -F "[ -x ${ADDON_DIR}/" "${TARG}" | cut -d':' -f1)"; [ -z "${LINE_NUM}" ] && return; printf "%s\n" "${LINE_NUM}" | sort -rn | while IFS= read -r LN; do [ -z "${LN}" ] && continue; sed -i "${LN}d" "${TARG}"; if [ ${LN} -gt 1 ]; then local ABOVE; ABOVE="$(sed "$((LN-1))q;d" "${TARG}")"; [ -z "${ABOVE}" ] && sed -i "$((LN-1))d" "${TARG}"; fi; done; [ "$(awk '{print}' "${TARG}")" = "#!/bin/sh" ] && rm -f "${TARG}"; }

download_file() {
	local TARG PERM URL RET FILENAME TMP_FILE TMP_MD5 MD5SUM_OLD MD5SUM_CURR MD5SUM_EXPECTED COUNT
	TARG="$1"; shift; PERM="$1"; shift; RET=0
	for URL in "$@"; do
		FILENAME="$(basename "${URL}")"; TMP_FILE="${TARG}/.${FILENAME}.$$"; TMP_MD5="${TMP_FILE}.md5sum"
		MD5SUM_OLD=""; MD5SUM_CURR=""; MD5SUM_EXPECTED=""; COUNT=0
		[ -f "${TARG}/${FILENAME}" ] && MD5SUM_OLD="$(md5sum "${TARG}/${FILENAME}" | awk '{print $1;exit}')"
		while [ ${COUNT} -lt 3 ]; do
			PTXT "Downloading ${FILENAME}"; rm -f "${TMP_FILE}" "${TMP_MD5}"
			if http_get_file "${URL}" "${TMP_FILE}" "" insecure && [ -s "${TMP_FILE}" ]; then
				MD5SUM_CURR="$(md5sum "${TMP_FILE}" | awk '{print $1;exit}')"
				MD5SUM_EXPECTED=""
				if http_get_file "${URL}.md5sum" "${TMP_MD5}" "" insecure && [ -s "${TMP_MD5}" ]; then MD5SUM_EXPECTED="$(awk 'NR==1{print $1;exit}' "${TMP_MD5}")"; fi
				if md5_is_valid "${MD5SUM_EXPECTED}"; then if [ "${MD5SUM_CURR}" = "${MD5SUM_EXPECTED}" ]; then break; fi; PTXT "${WARNING}Checksum mismatch; retrying."; else break; fi
			fi
			COUNT=$((COUNT+1))
		done
		rm -f "${TMP_MD5}"
		if [ ${COUNT} -eq 3 ]; then rm -f "${TMP_FILE}"; PTXT "${ERROR}Unable to download ${URL}"; RET=$((RET+1)); continue; fi
		if md5_is_valid "${MD5SUM_CURR}" && [ "${MD5SUM_CURR}" = "${MD5SUM_OLD}" ]; then rm -f "${TMP_FILE}"; PTXT "${FILENAME} up to date. Skipping..."; continue; fi
		if mv "${TMP_FILE}" "${TARG}/${FILENAME}" && chmod "${PERM}" "${TARG}/${FILENAME}"; then continue; fi
		rm -f "${TMP_FILE}"; PTXT "${ERROR}Unable to install ${FILENAME}"; RET=$((RET+1))
	done
	[ ${RET} -ne 0 ] && PTXT "${ERROR}One or more download failures."
	return ${RET}
}

backup_restore() {
	if [ "$1" = "BACKUP" ] && [ -d "${TARG_DIR}" ] && [ -f "${AGH_FILE}" ]; then
		[ -f "${BASE_DIR}/backup_AdGuardHome.tar.gz" ] && { read_yesno "Old backup found. Remove it?" && rm -f "${BASE_DIR}/backup_AdGuardHome.tar.gz" || { end_op_message 1; return; }; }
		PTXT "Backing up AdGuardHome..."; tar -czvf "${BASE_DIR}/backup_AdGuardHome.tar.gz" -C "${TARG_DIR}" ../AdGuardHome/ >/dev/null 2>&1; PTXT "Backup complete"
		[ -z "$2" ] && end_op_message 0 || return 0
	elif [ "$1" = "BACKUP" ]; then PTXT "${ERROR}No AdGuardHome to backup!"; end_op_message 1; fi
	if [ -f "${BASE_DIR}/backup_AdGuardHome.tar.gz" ] && [ "$1" = "RESTORE" ]; then
		PTXT "Restoring..."; local IPSET_MARKER_BACKUP="/tmp/AdGuardHome-ipset.user.restore.$$"; rm -f "${IPSET_MARKER_BACKUP}"
		[ -f "${TARG_DIR}/ipset.user" ] && mv "${TARG_DIR}/ipset.user" "${IPSET_MARKER_BACKUP}" || true
		tar -xzvf "${BASE_DIR}/backup_AdGuardHome.tar.gz" -C "${BASE_DIR}" >/dev/null 2>&1 || { [ -f "${IPSET_MARKER_BACKUP}" ] && mv "${IPSET_MARKER_BACKUP}" "${TARG_DIR}/ipset.user"; PTXT "${ERROR}Restore failed!"; return 1; }
		rm -f "${IPSET_MARKER_BACKUP}"; chown "$(nvram get http_username)":root ${TARG_DIR}/*; chmod 755 "${AGH_FILE}"; chmod 644 "${YAML_FILE}"
		[ -f "/opt/sbin/AdGuardHome" ] && rm -f /opt/sbin/AdGuardHome; ln -sf "${AGH_FILE}" /opt/sbin/AdGuardHome; inst_AdGuardHome "${1:-RESTORE}"
	elif [ ! -f "${BASE_DIR}/backup_AdGuardHome.tar.gz" ] && [ "$1" = "RESTORE" ]; then PTXT "${ERROR}No backup found!"; end_op_message 1; fi
}

cleanup() { mv "/opt/etc/init.d/S61AdGuardHome" "/opt/etc/init.d/S99AdGuardHome" >/dev/null 2>&1; [ "$(cru l | grep -c "S99AdGuardHome")" -gt 0 ] && cru -d "S99AdGuardHome"; [ -f "${TARG_DIR}/localtime" ] && mv "${TARG_DIR}/localtime" "${ADDON_DIR}/localtime"; remove_conflicting_apache; }

cleanup_legacy_firewall() {
	[ -x "${ADDON_DIR}/AdGuardHome.sh" ] && grep -q 'Unload_IPTables' "${ADDON_DIR}/AdGuardHome.sh" && "${ADDON_DIR}/AdGuardHome.sh" firewall unload 2>/dev/null
	while iptables -t raw -D OUTPUT -j ADGUARDHOME 2>/dev/null; do :; done; iptables -t raw -F ADGUARDHOME 2>/dev/null; iptables -t raw -X ADGUARDHOME 2>/dev/null
	del_jffs_script /jffs/scripts/firewall-start
}

dnsmasq_delete_matching() {
	local CONFIG PATTERN SED_SCRIPT
	CONFIG="$1"; shift; SED_SCRIPT=""
	for PATTERN in "$@"; do SED_SCRIPT="${SED_SCRIPT}/^${PATTERN}.*$/d;"; done
	[ -n "${SED_SCRIPT}" ] || return 0
	sed -i "${SED_SCRIPT}" "${CONFIG}"
}

inst_AdGuardHome() {
	local ADGUARD_TAR="AdGuardHome_${ADGUARD_ARCH}.tar.gz"
	if [ -z "$2" ]; then
		if [ "${1:-RESTORE}" != "RESTORE" ]; then
			if [ ! -d "${TARG_DIR}" ] && [ -f "${BASE_DIR}/backup_AdGuardHome.tar.gz" ]; then
				read_yesno "Backup detected. Restore instead?" && { backup_restore RESTORE; return; }
			elif [ -d "${TARG_DIR}" ] && [ -f "${AGH_FILE}" ] && [ ! -f "${BASE_DIR}/backup_AdGuardHome.tar.gz" ]; then
				read_yesno "Backup before updating?" && backup_restore BACKUP 0
			fi
		fi
		if ! check_connection; then PTXT "${ERROR}No internet!"; end_op_message 1 "$1"; return; fi
		check_dns_environment 0
		create_dir "${TARG_DIR}" || { end_op_message 1 "$1"; return; }
		download_file "${TARG_DIR}" 755 "${RURL}/installer" || { PTXT "${ERROR}Failed to download installer."; rmdir "${TARG_DIR}" 2>/dev/null; end_op_message 1 "$1"; return; }
		if [ "${1:-RESTORE}" != "RESTORE" ]; then
			[ "${1:-install}" != "update" ] && choose_branch
			local ADGUARD_BRANCH="$(conf_value ADGUARD_BRANCH)"
			if [ ! -f "${AGH_FILE}" ]; then inst_AdGuardHome "${1:-install}" "$ADGUARD_BRANCH"
			else
				local ADGUARD_VER="$("${AGH_FILE}" --version | cut -d" " -f4-)"; [ -z "${ADGUARD_VER}" ] && exit 1
				local REMOTE_ADGUARD_VER="$(adguard_remote_version "${ADGUARD_BRANCH}")"; [ -z "${REMOTE_ADGUARD_VER}" ] && exit 1
				if [ "${REMOTE_ADGUARD_VER}" != "${ADGUARD_VER}" ] || [ "${ADGUARD_BRANCH}" = "edge" ] || [ "${ADGUARD_BRANCH_CHANGED:-0}" = "1" ]; then
					inst_AdGuardHome "${1:-update}" "${ADGUARD_BRANCH}"
				else PTXT "ADGUARDHOME_VER=${ADGUARD_VER} (current)"; fi
			fi
		fi
	else
		local REMOTE_ADGUARD_ARCHIVE="$(adguard_remote_archive "$2")"
		local REMOTE_ADGUARD_URL="$(adguard_remote_url "$2")"
		[ -z "${REMOTE_ADGUARD_ARCHIVE}" ] && REMOTE_ADGUARD_ARCHIVE="${ADGUARD_TAR}"
		[ -z "${REMOTE_ADGUARD_URL}" ] && REMOTE_ADGUARD_URL="${URL_ARCH}/${REMOTE_ADGUARD_ARCHIVE}"
		if ! download_file "${BASE_DIR}" 644 "${REMOTE_ADGUARD_URL}"; then PTXT "${ERROR}Unable to get AdGuardHome binary"; end_op_message 1 "$1"; return; fi
		agh_prepare_binary_replace || return 1
		tar xzv -C "${BASE_DIR}" -f "${BASE_DIR}/${REMOTE_ADGUARD_ARCHIVE}" 2>&1
		chown "$(nvram get http_username)":root ${TARG_DIR}/*; rm -f "${BASE_DIR:?}/${REMOTE_ADGUARD_ARCHIVE}"
		chmod 755 "${AGH_FILE}"; [ -f "/opt/sbin/AdGuardHome" ] && rm -f /opt/sbin/AdGuardHome
		ln -sf "${AGH_FILE}" /opt/sbin/AdGuardHome || { PTXT "${ERROR}Failed to install binary."; end_op_message 1 "$1"; return; }
	fi
	create_dir "${ADDON_DIR}"; cleanup_legacy_firewall
	download_file "${ADDON_DIR}" 755 "${RURL}/AdGuardHome.sh"
	download_file "/opt/etc/init.d" 755 "${RURL}/S99AdGuardHome"
	download_file "/opt/etc/init.d" 644 "${RURL}/rc.func.AdGuardHome"
	[ -f "/jffs/scripts/dnsmasq.postconf" ] && yaml_nvars_delete "#Asuswrt-Merlin AdGuardHome Installer" /jffs/scripts/dnsmasq.postconf 2>/dev/null
	for i in init-start services-stop; do if ! grep -q "${ADDON_DIR}/AdGuardHome.sh $i &" "/jffs/scripts/${i}" 2>/dev/null && grep -q "${ADDON_DIR}/AdGuardHome.sh $i" "/jffs/scripts/${i}" 2>/dev/null; then del_jffs_script "/jffs/scripts/${i}"; fi; done
	write_manager_script /jffs/scripts/init-start "init-start &"
	write_manager_script /jffs/scripts/services-stop "services-stop &"
	write_manager_script /jffs/scripts/dnsmasq.postconf dnsmasq
	write_manager_script /jffs/scripts/firewall-start 'firewall "$1"'
	[ "$(nvram get rc_support 2>/dev/null)" = "mtlancfg" ] && { del_jffs_script /jffs/scripts/dnsmasq-sdn.postconf 2>/dev/null; write_manager_script /jffs/scripts/dnsmasq-sdn.postconf 'dnsmasq-sdn $2'; }
	{ mkdir -p /jffs/configs; local LAN_IP; LAN_IP="$(nvram get lan_ipaddr 2>/dev/null)"; [ -n "${LAN_IP}" ] && { dnsmasq_delete_matching /jffs/configs/dnsmasq.conf.add "port=" "dhcp-option=lan,6"; printf "%s\n" "dhcp-option=lan,6,${LAN_IP}" "port=553" >>/jffs/configs/dnsmasq.conf.add; }; }
	del_between_magic /jffs/scripts/service-event-end '# Asuswrt-Merlin-AdGuardHome-Installer'
	write_command_script /jffs/scripts/service-event-end 'if printf "%s" "$@" | /bin/grep -qE "^(((start|stop|restart|kill|reload)_?.*AdGuardHome)$)"; then { sh /jffs/addons/AdGuardHome.d/AdGuardHome.sh "$(printf "%s" "$@" | /bin/grep -oE "(start|stop|restart|kill|reload)")" x & }; fi # Asuswrt-Merlin-AdGuardHome-Installer'
	if [ "${1:-update}" != "update" ]; then
		[ ! -f "${ADDON_DIR}/localtime" ] && set_timezone
		setup_AdGuardHome "" "${1:-install}" || { end_op_message 1; return; }
	fi
	agh_complete_startup || { end_op_message 1 "$1"; return; }
	end_op_message 0 "$1"
}

setup_AdGuardHome() {
	if [ ! -d "${TARG_DIR}" ] || [ ! -f "${AGH_FILE}" ]; then PTXT "${ERROR}AdGuardHome not installed. Aborting."; return 1; fi
	PTXT "Configuring AdGuardHome..."; setup_AdGuardHome_impl "$@"; local RET="$?"
	[ "$1" = "reconfig" ] && { [ ${RET} -eq 0 ] && { PTXT "Restarting..."; agh_restart || { agh_start_error; end_op_message 1; return; }; PTXT "Setup complete."; }; end_op_message 0; }; return ${RET}
}

setup_AdGuardHome_impl() {
	local SCHEMA_VER="$("${AGH_FILE}" -v --version | awk '/Schema[[:space:]]version:/{ print $NF }' 2>/dev/null)"; [ -z "${SCHEMA_VER}" ] && SCHEMA_VER="27"
	if [ -z "$1" ] && [ -f "${YAML_FILE}" ]; then
		if ! awk -F'=' '/ADGUARD_WEBUI_PORT/ {print $2}' "${CONF_FILE}" 2>/dev/null | sed -e 's/^"//' -e 's/"$//' | grep -qoE '^(3000|[3-9][0-9]{3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5])$'; then
			PTXT "Set preferred Web Port for AdGuardHome WebUI (3000-65535)."
			read_input_port "Default is" 3000
			write_conf ADGUARD_WEBUI_PORT "\"${WEB_PORT}\""
			yaml_nvars_replace "  address: 0.0.0.0:$(awk -F':' '/.*address\:.*/{ print $3 }' "${YAML_FILE}" | grep -oE '[0-9]+$')" "  address: 0.0.0.0:${WEB_PORT}" "${YAML_FILE}"
		fi
		if [ -n "$(awk -F': ' '/.*schema\:.*/{ print $2 }' "${YAML_FILE}")" ] && [ "$(awk -F': ' '/.*schema\:.*/{ print $2 }' "${YAML_FILE}")" != "${SCHEMA_VER}" ]; then yaml_nvars_replace "schema_version: $(awk -F': ' '/.*schema\:.*/{ print $2 }' "${YAML_FILE}")" "schema_version: ${SCHEMA_VER}" "${YAML_FILE}"; fi
		if ! check_AdGuardHome_yaml; then setup_AdGuardHome_impl x; return; fi
		read_yesno "Use existing config?" || setup_AdGuardHome_impl x
	else
		if [ -f "${YAML_FILE}" ]; then
			[ "$1" = "reconfig" ] && { check_AdGuardHome_yaml || { setup_AdGuardHome_impl x; return; }; }
			PTXT "Reconfigure:" "  1) Use existing" "  2) Restore original" "  3) New configuration"
			read_input_num "Your selection" 1 3
			case "${CHOSEN}" in
				1) PTXT "Using existing config.";;
				2|3) PTXT "Backing up previous config..."; mv "${YAML_FILE}" "${YAML_BAK}"; [ "${CHOSEN}" = "3" ] && rm -f "${YAML_ORI}" 2>/dev/null || cp -f "${YAML_ORI}" "${YAML_FILE}";;
			esac
		elif [ ! -f "${YAML_FILE}" ] && [ -f "${YAML_ORI}" ]; then cp -f "${YAML_ORI}" "${YAML_FILE}"; fi
		case "${2:-reconfig}" in
			"install"|"reconfig")
				if [ ! -f "${YAML_FILE}" ] || [ "$2" = "reconfig" ]; then
					read_yesno "Redirect all DNS to AdGuardHome?" && check_dns_filter 1 || check_dns_filter 0
					[ "$(nvram get dns_local_cache)" != "1" ] && read_yesno "Run AdGuardHome as local caching DNS?" && check_dns_local 1 || check_dns_local 0
				fi
				if [ ! -f "${YAML_ORI}" ] && [ ! -f "${YAML_FILE}" ]; then
					PTXT "Initial configuration..."
					PTXT "Set Web Port (3000-65535)."
					read_input_port "Default is" 3000
					write_conf ADGUARD_WEBUI_PORT "\"${WEB_PORT}\""
					PTXT "http:" "  address: 0.0.0.0:${WEB_PORT}" >"${YAML_ORI}"
					PTXT "Set username and password."; AdGuardHome_authen 1
					PTXT "dns:" "  bind_hosts:" "    - 0.0.0.0" "  port: 53" >>"${YAML_ORI}"
					PTXT "Set upstream DNS servers:"; read_input_dns "Primary" 1.1.1.1; read_input_dns "Secondary" 8.8.8.8
					local DOMAIN NET_ADDR NET_ADDR6 LAN_IF
					LAN_IF="$(nvram get lan_ifname)"; NET_ADDR="$(ip -o -4 addr list "${LAN_IF}" | awk 'NR==1{split($4,ip,"/");print ip[1]}' 2>/dev/null || nvram get lan_ipaddr)"
					NET_ADDR6="$(ip -o -6 addr list "${LAN_IF}" scope global | awk 'NR==1{split($4,ip,"/");print ip[1]}' 2>/dev/null || nvram get ipv6_rtr_addr)"
					[ -n "$(nvram get lan_domain)" ] && DOMAIN="$(nvram get lan_domain)" && write_conf ADGUARD_DOMAIN "\"no\""
					[ -z "$(nvram get lan_domain)" ] && DOMAIN="lan" && nvram set lan_domain="${DOMAIN}" && nvram commit && write_conf ADGUARD_DOMAIN "\"yes\""
					PTXT "  upstream_dns:" >>"${YAML_ORI}"
					[ -n "${NET_ADDR6}" ] && PTXT "  - '[/$(printf "%s\n" "${NET_ADDR6}" | sed 's/.$//' | awk -F: '{for(i=1;i<=NF;i++)x=x""sprintf (":%4s", $i);gsub(/ /,"0",x);printf x}' | cut -c 2- | cut -c 1-20 | sed 's/://g;s/^.*$/\n&\n/;tx;:x;s/\(\n.\)\(.*\)\(.\n\)/\3\2\1/;tx;s/\n//g;s/\(.\)/\1./g;s/$/ip6.arpa/')/][::]:553'" >>"${YAML_ORI}"
					PTXT "  - '[/router.asus.com/][::]:553'" "  - '[/www.asusnetwork.net/][::]:553'" "  - '[/www.asusrouter.com/][::]:553'" "  - '[/use-application-dns.net/][::]:553'" "  - '[/dns.resolver.arpa/][::]:553'" "  - '[/${DOMAIN}/][::]:553'" "  - '[//][::]:553'" "  - ${BOOTSTRAP1}" "  - ${BOOTSTRAP2}" "  - tcp://${BOOTSTRAP1}" "  - tcp://${BOOTSTRAP2}" "  bootstrap_dns:" "  - ${BOOTSTRAP1}" "  - ${BOOTSTRAP2}" "  fallback_dns:" "  - ${BOOTSTRAP1}" "  - ${BOOTSTRAP2}" "  - tcp://${BOOTSTRAP1}" "  - tcp://${BOOTSTRAP2}" "  resolve_clients: true" "  use_private_ptr_resolvers: true" "  local_ptr_upstreams:" "  - '[::]:553'" "  - '[/10.in-addr.arpa/][::]:553'" "  - '[/$(printf "%s\n" "${NET_ADDR}" | awk 'BEGIN{FS="."}{print $2"."$1".in-addr.arpa"}')/][::]:553'" "schema_version: ${SCHEMA_VER}" >>"${YAML_ORI}"
					PTXT "Writing configuration..."; cp -f "${YAML_ORI}" "${YAML_FILE}"
				fi
				check_AdGuardHome_yaml || { PTXT "${ERROR}Config write failed."; return 1; };;
		esac
	fi
}

setup_amtmupdate() { local AMTM_UPDATE; local CURRENT_AMTM_UPDATE="$(conf_value AMTM_UPDATE)"; [ -z "${CURRENT_AMTM_UPDATE}" ] || [ "${CURRENT_AMTM_UPDATE}" = "DISABLED" ] && AMTM_UPDATE="ENABLED" || AMTM_UPDATE="DISABLED"; PTXT "Setting AMTM Update to ${AMTM_UPDATE}."; write_conf AMTM_UPDATE "\"${AMTM_UPDATE}\""; end_op_message 0; }

 uninst_all() {
 	agh_stop; cleanup_legacy_firewall
 	[ "$(conf_value ADGUARD_DOMAIN)" = "yes" ] && nvram set lan_domain="" && nvram commit
 	mv "${TARG_DIR}/installer" "${HOME}/installer" 2>/dev/null
 	rm -rf "${TARG_DIR}" "/opt/etc/init.d/S99AdGuardHome" "/opt/etc/init.d/rc.func.AdGuardHome" "/opt/sbin/AdGuardHome" "/opt/bin/bcrypt-tool" "${ADDON_DIR}" "/opt/var/log/AdGuardHome.log" "/opt/etc/backup_AdGuardHome.tar.gz" "/jffs/configs/dnsmasq.d/aghome.conf" "/jffs/configs/dnsmasq.conf.add"
 	yaml_nvars_delete "#Asuswrt-Merlin AdGuardHome Installer" /jffs/scripts/dnsmasq.postconf 2>/dev/null
 	for s in init-start dnsmasq.postconf firewall-start services-stop; do
 		del_jffs_script "/jffs/scripts/${s}" 2>/dev/null
 		sed -i '/\/jffs\/addons\/AdGuardHome\.d\//d' "/jffs/scripts/${s}" 2>/dev/null
 		[ "$(awk 'NR>1{print;exit}' "/jffs/scripts/${s}" 2>/dev/null)" = "" ] && rm -f "/jffs/scripts/${s}" 2>/dev/null
 	done
 	[ "$(nvram get rc_support 2>/dev/null)" = "mtlancfg" ] && del_jffs_script /jffs/scripts/dnsmasq-sdn.postconf 2>/dev/null
 	del_between_magic /jffs/scripts/service-event-end '# Asuswrt-Merlin-AdGuardHome-Installer'
 	sed -i '/AdGuardHome/d' /jffs/scripts/service-event-end 2>/dev/null
 	[ "$(awk 'NR>1{print;exit}' /jffs/scripts/service-event-end 2>/dev/null)" = "" ] && rm -f /jffs/scripts/service-event-end 2>/dev/null
 	service restart_dnsmasq >/dev/null 2>&1; end_op_message 0
 }

# --- Write helpers ---
write_command_script() {
	local TARG="$1" COMMAND="$2" FN; FN="$(basename "${TARG}")"
	[ ! -f "${TARG}" ] && { PTXT "Creating ${TARG}"; PTXT "#!/bin/sh" >"${TARG}"; }; chmod 755 "${TARG}"
	grep -q -F "${COMMAND}" "${TARG}" && PTXT "${TARG} already configured" || { PTXT "Configure ${TARG}"; PTXT "${COMMAND}" >>"${TARG}"; }
}

write_conf() {
	local VAR="$1" VALUE="$2"
	if [ ! -f "${CONF_FILE}" ]; then touch "${CONF_FILE}" && chmod 644 "${CONF_FILE}" || { PTXT "${ERROR}Unable to create config."; return 1; }; fi
	if grep -q "^${VAR}=" "${CONF_FILE}"; then VALUE=$(_quote "${VALUE}"); sed -i "/^${VAR}=/s/=.*/=${VALUE}/" "${CONF_FILE}"
	else PTXT "${VAR}=${VALUE}" >>"${CONF_FILE}"; fi
}

write_manager_script() {
	local TARG="$1" OP="$2" CMD="${ADDON_DIR}/AdGuardHome.sh"
	[ ! -f "${TARG}" ] && { PTXT "Creating ${TARG}"; PTXT "#!/bin/sh" >"${TARG}"; }; chmod 755 "${TARG}" "${CMD}" 2>/dev/null
	del_between_magic "${TARG}" Asuswrt-Merlin-AdGuardHome-Installer
	if [ "$(grep -c -F "[ -x ${CMD} ] && ${CMD} ${OP}" "${TARG}")" -gt 0 ]; then PTXT "${TARG} already configured"
	else PTXT "Configure ${TARG}"; del_jffs_script "${TARG}" !manager; [ "$(tail -1 "${TARG}" | grep -c '^$')" -eq 0 ] && PTXT "" >>"${TARG}"; PTXT "[ -x ${CMD} ] && ${CMD} ${OP}" >>"${TARG}"; fi
}

yaml_nvars_append() { echo "$1" >>"$2"; }
yaml_nvars_delete() { sed -i "/$(_quote "$1")/d" "$2"; }
yaml_nvars_insert() { sed -i "/$(_quote "$1")/a$(_quote "$2")" "$3"; }
yaml_nvars_replace() { sed -i "s/$(_quote "$1")/$(_quote "$2")/" "$3"; }

# ===== INTERACTIVE MENU =====
end_op_header() { sed -n -e "1,$(($(grep -wn 'esac' "$0" | cut -d':' -f1 | tail -n1)+1))p" "$0" >"${0}.tmp"; chmod 755 "${0}.tmp"; exec "${0}.tmp" "${BRANCH}" && rm -f "${0}.tmp"; }

end_op_message() {
	case "${1:-0}" in
		0) [ "$2" = "update" ] && exit 0; PTXT "Operation completed.";;
		1) [ "$2" = "update" ] && exit 1; PTXT "Operation aborted.";;
		2) PTXT "Abnormal operations.";;
	esac
	PTXT "====================================================="; PTXT " "; PTXT " "
	sleep 3s && clear
	[ ! -t 0 ] && exit 0
	if [ -f "${TARG_DIR}/installer" ]; then chmod 755 "${TARG_DIR}/installer" >/dev/null 2>&1; exec "${TARG_DIR}/installer" "${BRANCH}"
	elif [ -f "${SCRIPT_LOC}" ]; then chmod 755 "${SCRIPT_LOC}" >/dev/null 2>&1; exec "${SCRIPT_LOC}" "${BRANCH}"
	elif [ -f "${HOME}/installer" ]; then chmod 755 "${HOME}/installer"; exec "${HOME}/installer" "${BRANCH}"
	else clear && end_op_header 2>/dev/null; fi
	exit $?
}

menu() {
	trap - HUP INT QUIT ABRT TERM
	case "$1" in "")
		PTXT "Choose option:" "  1) Install/Update" "  2) Uninstall"
		local max=2 args=""
		if [ -d "${TARG_DIR}" ] && [ -f "${AGH_FILE}" ]; then
			PTXT "  3) Change Password" "  4) Reconfigure" "  5) AMTM updates" "  b) Backup"
			max=5; args="q b"
			[ -f "${BASE_DIR}/backup_AdGuardHome.tar.gz" ] && args="${args} r"
		else args="q"; fi
		PTXT "  q) Quit"
		read_input_num "Selection" 1 ${max} ${args};; *) CHOSEN="$1";; esac
	[ -n "${CHOSEN}" ] && trap 'clear; end_op_message 2' HUP INT QUIT ABRT TERM
	case "${CHOSEN}" in
		1|install|update) PTXT "Installing AdGuardHome..."; inst_AdGuardHome "install";;
		2|uninstall) read_yesno "Uninstall AdGuardHome?" && uninst_all || end_op_message 1;;
		3|changepw) read_yesno "Change password?" && AdGuardHome_authen 0 || end_op_message 1;;
		4|reconfigure) read_yesno "Reconfigure?" && setup_AdGuardHome reconfig || end_op_message 1;;
		5|setamtmupdate) setup_amtmupdate;;
		b|B|backup) read_yesno "Backup?" && backup_restore BACKUP || end_op_message 1;;
		r|R|restore) read_yesno "Restore?" && backup_restore RESTORE || end_op_message 1;;
		q|Q) PTXT "Goodbye."; [ -f "${HOME}/installer" ] && rm -f "${HOME}/installer"; sleep 3s; clear;;
	esac
}

# ===== INPUT HELPERS =====
read_input_num() {
	local RANGE="[${2}-${3}${4:+/$4}${5:+/$5}${6:+/$6}]"
	PTXT -n "${INPUT}${1}, ${BOLD}${RANGE}${NORM}: "; read -r CHOSEN || { PTXT "\n${ERROR}Input closed."; exit 1; }
	[ -z "${CHOSEN}" ] && { read_input_num "$@"; return; }
	case "${CHOSEN}" in $4|$5|$6) return 1;; esac
	PTXT "${CHOSEN}" | grep -qE '^[0-9]+$' || { read_input_num "$@"; return; }
	[ ${CHOSEN} -lt $2 ] || [ ${CHOSEN} -gt $3 ] && { read_input_num "$@"; return; }
}

read_input_port() {
	PTXT -n "${INPUT}${1} ${BOLD}${2}: ${NORM}"; read -r WEB_PORT || { PTXT "\n${ERROR}Input closed."; exit 1; }; [ -z "${WEB_PORT}" ] && WEB_PORT="$2"
	PTXT "${WEB_PORT}" | grep -qoE '^(3000|[3-9][0-9]{3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5])$' && [ ${WEB_PORT} -ge 3000 ] && [ ${WEB_PORT} -le 65535 ] || { PTXT "${ERROR}Invalid port (3000-65535)."; read_input_port "$@"; return; }
	netstat -nlp 2>/dev/null | grep -qE "(:${WEB_PORT}[[:space:]])" && { PTXT "${ERROR}Port ${WEB_PORT} in use."; read_input_port "$@"; }
}

read_input_dns() {
	PTXT -n "${INPUT}${1} ${BOLD}${2}: ${NORM}"; read -r DNS_SERVER || { PTXT "\n${ERROR}Input closed."; exit 1; }; [ -z "${DNS_SERVER}" ] && DNS_SERVER="$2"
	PTXT "${DNS_SERVER}" | grep -qoE "\b((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\b" || { PTXT "${ERROR}Invalid DNS."; read_input_dns "$@"; return; }
	[ "${DNS_SERVER1}" = "${DNS_SERVER}" ] && { PTXT "${ERROR}Duplicate DNS."; read_input_dns "$@"; return; }
	case "$1" in Primary) BOOTSTRAP1="${DNS_SERVER}"; DNS_SERVER1="${DNS_SERVER}";; Secondary) BOOTSTRAP2="${DNS_SERVER}";; esac
}

read_yesno() { PTXT -n "${INPUT}${1} ${BOLD}[y/n]${NORM}: "; local YN; read -r YN || { PTXT "\n${ERROR}Input closed."; exit 1; }; case "${YN}" in y|Y) return 0;; n|N) return 1;; *) PTXT "${ERROR}y/n only."; read_yesno "$@";; esac; }

on_installer_exit() { cleanup_api_files; [ ! -f "${AGH_FILE}" ] && check_dns_environment 1; }

