RURL="https://raw.githubusercontent.com/halibotee/AdguardHome/${BRANCH}"
ROUTER_OS="$(/bin/uname)"
! PTXT "${ROUTER_MODEL}" | grep -vE "RT-AC(86|2900)" | grep -q "AC" && ROUTER_ARCH="$(/bin/uname -m)" || ROUTER_ARCH="armv7"
NAT_ENV="$(nvram get wan_ipaddr 2>/dev/null | grep -oE '\b^(((10|127)(\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)){3})|(((172\.(1[6-9]|2[0-9]|3[0-1]))|(192\.168))(\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)){2}))$\b')"

[ ${OFFLINE_MODE} -eq 1 ] && PTXT "${INFO} OFFLINE MODE - Assets: ${OFFLINE_DIR}"
[ -n "${NAT_ENV}" ] && [ -z "$2" ] && [ ${OFFLINE_MODE} -eq 0 ] && PTXT "${WARNING} Double-NAT detected."

[ -z "$2" ] && { printf '\e[8;50;125t'; printf '\033[?7l'; clear; sed -n '2,4p' "$0"; printf '\033[?7h'; }

case "${ROUTER_OS}" in Linux) [ -z "$2" ] && PTXT "${INFO} Linux platform."; ROUTER_OS="linux";; *) PTXT "${ERROR} Unsupported OS."; exit 1;; esac
case "$(/bin/uname -m)" in
